# ── LLM Provider ──────────────────────────────────────────
# Using local Ollama — no API key needed
OLLAMA_BASE_URL=http://localhost:11434
# Optional cloud fallback:
# GROQ_API_KEY=gsk_...
# GOOGLE_API_KEY=AIza...

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
