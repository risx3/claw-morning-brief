{
  "gateway": { "mode": "local" },
  "logging": { "level": "info" },

  "agents": {
    "defaults": {
      "model": { "primary": "groq/llama-3.3-70b-versatile" },
      "workspace": "./workspace",
      "thinkingDefault": "off",
      "timeoutSeconds": 300,
      "heartbeat": { "every": "0m" },
      "skipBootstrap": true
    },
    "list": [
      {
        "id": "morning-brief",
        "default": true,
        "groupChat": {
          "mentionPatterns": ["@morningbrief", "brief"]
        }
      }
    ]
  },

  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "allowFrom": ["YOUR_CHAT_ID"],
      "streaming": { "mode": "off" }
    }
  },

  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 2,
    "retry": {
      "maxAttempts": 2,
      "backoffMs": [60000, 120000],
      "retryOn": ["rate_limit", "overloaded", "network"]
    }
  },

  "session": {
    "scope": "per-sender",
    "resetTriggers": ["/new", "/reset"],
    "reset": {
      "mode": "daily",
      "atHour": 4,
      "idleMinutes": 1440
    }
  }
}
